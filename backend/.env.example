SECRET_KEY=troque-por-uma-chave-segura
FLASK_ENV=production
PORT=5000

# Cole aqui o conteúdo COMPLETO do JSON da service account do Firebase
# (em uma única linha, sem quebras de linha extras)
# Firebase Console → Configurações → Service Accounts → Gerar nova chave privada
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"financeiro-lopes",...}
