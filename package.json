{
  "name": "wolfsource",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "WolfSource - Gestão Financeira",
  "scripts": {
    "copy": "node infra/scripts/copy-web.js",
    "sync": "node infra/scripts/copy-web.js && cd apps/mobile && npx cap sync android",
    "open:android": "cd apps/mobile && npx cap open android",
    "build": "node infra/scripts/copy-web.js && cd apps/mobile && npx cap sync android && npx cap open android",
    "icons:android": "node infra/scripts/generate-android-icons.js",
    "release": "node infra/scripts/release.js",
    "deploy": "node infra/scripts/copy-web.js && npx gh-pages -d www",
    "dev": "node infra/scripts/copy-web.js && npx serve www"
  },
  "dependencies": {
    "@capacitor-firebase/messaging": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "firebase-admin": "^13.8.0",
    "gh-pages": "^6.3.0",
    "sharp": "^0.34.5"
  }
}
