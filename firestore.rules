rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    function isAuthed() {
      return request.auth != null;
    }

    function myFamilyId() {
      return request.auth.token.familyId;
    }

    // role é incluído nas claims via backend (set_custom_user_claims)
    function isSuperAdmin() {
      return isAuthed() && request.auth.token.role == 'superadmin';
    }

    // Admin da família — pode gerenciar usuários dentro da própria família
    function isAdmin() {
      return isAuthed() && request.auth.token.role == 'admin';
    }

    function sameFamily(doc) {
      return isAuthed() && doc.data.familyId == myFamilyId();
    }

    function incomingFamilyOk() {
      return isAuthed() && request.resource.data.familyId == myFamilyId();
    }

    // ── users ─────────────────────────────────────────────────
    // Leitura pública para popular selects e fluxo de login SHA-256.
    // Superadmin pode criar/editar/excluir qualquer usuário.
    // Admin pode criar/editar/excluir usuários dentro da própria família.
    // Usuário comum pode apenas atualizar o próprio doc.
    match /users/{userId} {
      allow read: if true;
      allow create: if isSuperAdmin()
                    || (isAdmin() && incomingFamilyOk())
                    || (isAuthed() && request.auth.uid == userId && incomingFamilyOk());
      allow update: if isSuperAdmin()
                    || (isAdmin() && sameFamily(resource))
                    || (isAuthed() && request.auth.uid == userId);
      allow delete: if isSuperAdmin() || (isAdmin() && sameFamily(resource));
    }

    // ── families ──────────────────────────────────────────────
    // Leitura pública para popular selects de família no cadastro.
    // Superadmin pode criar, atualizar e excluir qualquer família.
    match /families/{familyId} {
      allow read: if true;
      allow create: if isSuperAdmin() || isAuthed();
      allow update: if isSuperAdmin() || (isAuthed() && myFamilyId() == familyId);
      allow delete: if isSuperAdmin();
    }

    // ── transactions ─────────────────────────────────────────
    match /transactions/{docId} {
      allow read:   if sameFamily(resource);
      allow create: if incomingFamilyOk();
      allow update: if sameFamily(resource) && incomingFamilyOk();
      allow delete: if sameFamily(resource);
    }

    // ── debts ─────────────────────────────────────────────────
    match /debts/{docId} {
      allow read:   if sameFamily(resource);
      allow create: if incomingFamilyOk();
      allow update: if sameFamily(resource) && incomingFamilyOk();
      allow delete: if sameFamily(resource);
    }

    // ── salaries ─────────────────────────────────────────────
    match /salaries/{docId} {
      allow read:   if sameFamily(resource);
      allow create: if incomingFamilyOk();
      allow update: if sameFamily(resource) && incomingFamilyOk();
      allow delete: if sameFamily(resource);
    }

    // ── shoppingLists ─────────────────────────────────────────
    match /shoppingLists/{docId} {
      allow read:   if sameFamily(resource);
      allow create: if incomingFamilyOk();
      allow update: if sameFamily(resource) && incomingFamilyOk();
      allow delete: if sameFamily(resource);
    }

    // ── conversations ─────────────────────────────────────────
    // Participantes podem ler/escrever na conversa e nas mensagens.
    match /conversations/{convId} {
      allow read:   if isAuthed() && request.auth.uid in resource.data.participantIds;
      allow create: if isAuthed() && request.auth.uid in request.resource.data.participantIds;
      allow update: if isAuthed() && request.auth.uid in resource.data.participantIds;
      allow delete: if isAuthed() && request.auth.uid in resource.data.participantIds;

      match /messages/{msgId} {
        allow read, write: if isAuthed() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds;
      }
    }

    // ── passwordResets ────────────────────────────────────────
    // Fluxo de recuperação de senha não tem auth — mantém aberto.
    match /passwordResets/{docId} {
      allow read, write: if true;
    }

    // ── Tudo mais: negar ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
